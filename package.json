{
  "name": "laurensverspeek.nl",
  "version": "2.0.0",
  "author": "Laurens Verspeek",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "lint:styles": "stylelint \"app/**/*.{scss,vue}\"",
    "typecheck": "nuxt typecheck",
    "typecheck:tests": "vue-tsc --noEmit -p tsconfig.tests.json",
    "knip": "npx knip",
    "test": "vitest run",
    "og": "node scripts/generate-og.mjs",
    "pregenerate": "node scripts/generate-og.mjs",
    "postgenerate": "node scripts/generate-resume.mjs",
    "resume": "node scripts/generate-resume.mjs",
    "test:e2e": "playwright test",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "test:nuxt": "vitest run --config vitest.nuxt.config.ts"
  },
  "dependencies": {
    "@nuxt/content": "^3.15.0",
    "bulma": "^1.0.4",
    "nuxt": "^4.0.0",
    "qrcode-generator": "^2.0.4",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/color-mode": "^3.5.2",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vue/test-utils": "^2.4.11",
    "@vueuse/core": "^13.0.0",
    "@vueuse/nuxt": "^13.0.0",
    "better-sqlite3": "^12.11.1",
    "eslint": "^10.6.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss-html": "^1.8.1",
    "sass": "^1.89.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.6",
    "ws": "^8.21.0"
  },
  "lint-staged": {
    "*.{ts,vue,mjs}": "eslint --fix",
    "*.{scss,vue}": "stylelint --fix"
  }
