#!/usr/bin/env sh
# Lint only the staged files, without lint-staged's git-stash backup step —
# lint-staged 16 on git 2.25 throws "Needed a single revision" whenever an
# untracked file is present, which forced every commit to use --no-verify.
# This is check-only and touches nothing in the working tree, so it works on
# any git version. Mirrors CI (eslint . / stylelint) but scoped to staged files.
staged=$(git diff --cached --name-only --diff-filter=ACMR)
[ -z "$staged" ] && exit 0

js=$(printf '%s\n' "$staged" | grep -E '\.(ts|vue|mjs)$' || true)
styles=$(printf '%s\n' "$staged" | grep -E '\.(scss|vue)$' || true)

status=0
if [ -n "$js" ]; then
  echo "$js" | xargs eslint || status=1
fi
if [ -n "$styles" ]; then
  echo "$styles" | xargs stylelint || status=1
fi
[ "$status" != 0 ] && echo "pre-commit: fix the lint errors above, or commit with --no-verify to skip"
exit $status
