class":59},"  onEnd",[46,100,73],{"class":63},[46,102,103],{"class":76},"lines",[46,105,80],{"class":52},[46,107,84],{"class":83},[46,109,110],{"class":63},"[])",[46,112,80],{"class":52},[46,114,92],{"class":83},[46,116,118],{"class":48,"line":117},4,[46,119,120],{"class":63},"}\n",[10,122,123,124,127,128,131,132,135,136,138],{},"Every tick, snake builds the whole board as a string — box-drawing characters for the walls, ",[20,125,126],{},"█"," for the body, ",[20,129,130],{},"●"," for the food — and hands it to ",[20,133,134],{},"onFrame",". Vue re-renders the ",[20,137,26],{},", and because the font is monospace, the \"pixels\" line up perfectly:",[37,140,142],{"className":39,"code":141,"language":41,"meta":42,"style":42},"function render() {\n  const grid = buildGrid()          \u002F\u002F 26 × 12 characters\n  grid[food.y][food.x] = '●'\n  snake.forEach((cell, i) => {\n    grid[cell.y][cell.x] = i === 0 ? '▓' : '█'\n  })\n  onFrame(header + grid.map((row) => row.join(' ')).join('\\n'))\n}\n",[20,143,144,155,176,188,216,245,251,306],{"__ignoreMap":42},[46,145,146,149,152],{"class":48,"line":49},[46,147,148],{"class":52},"function",[46,150,151],{"class":59}," render",[46,153,154],{"class":63},"() {\n",[46,156,157,160,163,166,169,172],{"class":48,"line":67},[46,158,159],{"class":52},"  const",[46,161,162],{"class":83}," grid",[46,164,165],{"class":52}," =",[46,167,168],{"class":59}," buildGrid",[46,170,171],{"class":63},"()          ",[46,173,175],{"class":174},"sJ8bj","\u002F\u002F 26 × 12 characters\n",[46,177,178,181,184],{"class":48,"line":95},[46,179,180],{"class":63},"  grid[food.y][food.x] ",[46,182,183],{"class":52},"=",[46,185,187],{"class":186},"sZZnC"," '●'\n",[46,189,190,193,196,199,202,205,208,211,214],{"class":48,"line":117},[46,191,192],{"class":63},"  snake.",[46,194,195],{"class":59},"forEach",[46,197,198],{"class":63},"((",[46,200,201],{"class":76},"cell",[46,203,204],{"class":63},", ",[46,206,207],{"class":76},"i",[46,209,210],{"class":63},") ",