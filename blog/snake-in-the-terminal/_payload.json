8],{"__ignoreMap":43},[47,332,333,336,338,341,344,347,349,351],{"class":49,"line":50},[47,334,335],{"class":60},"useEventListener",[47,337,74],{"class":64},[47,339,340],{"class":187},"'keydown'",[47,342,343],{"class":64},", (",[47,345,346],{"class":77},"event",[47,348,211],{"class":64},[47,350,214],{"class":53},[47,352,65],{"class":64},[47,354,355,358,361,364,367,370,373,376],{"class":49,"line":68},[47,356,357],{"class":53},"  if",[47,359,360],{"class":64}," (",[47,362,363],{"class":53},"!",[47,365,366],{"class":64},"isOpen.value ",[47,368,369],{"class":53},"||",[47,371,372],{"class":53}," !",[47,374,375],{"class":64},"activeGame.value) ",[47,377,378],{"class":53},"return\n",[47,380,381,383,386,389,392,395],{"class":49,"line":96},[47,382,357],{"class":53},[47,384,385],{"class":64}," (activeGame.value.",[47,387,388],{"class":60},"onKey",[47,390,391],{"class":64},"(event.key)) event.",[47,393,394],{"class":60},"preventDefault",[47,396,397],{"class":64},"()\n",[47,399,400],{"class":49,"line":118},[47,401,402],{"class":64},"})\n",[11,404,405,406,409,410,413,414,417,418,421],{},"The game returns ",[21,407,408],{},"true"," for keys it consumed, so arrows stop scrolling the page but ",[21,411,412],{},"F5"," still works. ",[21,415,416],{},"q"," and ",[21,419,420],{},"Escape"," end the game instead of closing the terminal — that one took a bug report from myself to get right.",[30,423,425],{"id":424},"the-segfault","the segfault",[11,427,428],{},"When you die, the terminal prints:",[38,430,434],{"className":431,"code":432,"language":433,"meta":43,"style":43},"language-bash shiki shiki-themes github-light github-dark","game over — the snake has encountered a segfault\nfinal score: 120\nnew high score! previous best: 80\n","bash",[21,435,436,465,476],{"__ignoreMap":43},[47,437,438,441,444,447,450,453,456,459,462],{"class":49,"line":50},[47,439,440],{"class":60},"game",[47,442,443],{"class":187}," over",[47,445,446],{"class":187}," —",[47,448,449],{"class":187}," the",[47,451,452],{"class":187}," snake",[47,454,455],{"class":187}," has",[47,457,458],{"class":187}," encountered",[47,460,461],{"class":187}," a",[47,463,464],{"class":187}," segfault\n",[47,466,467,470,473],{"class":49,"line":68},[47,468,469],{"class":60},"final",[47,471,472],{"class":187}," score:",[47,474,475],{"class":84}," 120\n",[47,477,478,481,484,487,490,493],{"class":49,"line":96},[47,479,480],{"class":60},"new",[47,482,483],{"class":187}," high",[47,485,486],{"class":187}," score!",[47,488,489],{"class":187}," previous",[47,491,492],{"class":187}," best:",[47,494,495],{"class":84}," 80\n",[11,497,498,499,502],{},"High scores persist in ",[21,500,501],{},"localStorage",", because if you're going to lose to a snake made of Unicode blocks, the least I can do is remember it.",[11,504,505,506,509,510,512],{},"Try it: press ",[21,507,508],{},"~",", type ",[21,511,23],{},". My high score is embarrassing, please beat it.",[514,515,516],"style",{},"html pre.shiki code .szBVR, html code.shiki .szBVR{--shiki-default:#D73A49;--shiki-dark:#F97583}html pre.shiki code .sScJk, html code.shiki .sScJk{--shiki-default:#6F42C1;--shiki-dark:#B392F0}html pre.shiki code .sVt8B, html code.shiki .sVt8B{--shiki-default:#24292E;--shiki-dark:#E1E4E8}html pre.shiki code .s4XuR, html code.shiki .s4XuR{--shiki-default:#E36209;--shiki-dark:#FFAB70}html pre.shiki code .sj4cs, html code.shiki .sj4cs{--shiki-default:#005CC5;--shiki-dark:#79B8FF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shik